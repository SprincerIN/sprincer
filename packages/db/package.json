{
  "name": "@sprincer/db",
  "version": "0.0.1",
  "private": true,
  "description": "Sprincer database - Drizzle schema and migrations",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/seed.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.40.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@sprincer/config": "workspace:*",
    "@types/bun": "^1.2.5",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.8.2"
  }
}
