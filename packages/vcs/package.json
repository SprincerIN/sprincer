{
  "name": "@sprincer/vcs",
  "version": "0.0.1",
  "private": true,
  "description": "Sprincer VCS provider abstraction",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./providers/github": {
      "types": "./src/providers/github.ts",
      "default": "./src/providers/github.ts"
    },
    "./providers/gitlab": {
      "types": "./src/providers/gitlab.ts",
      "default": "./src/providers/gitlab.ts"
    }
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sprincer/types": "workspace:*",
    "octokit": "^4.1.2"
  },
  "devDependencies": {
    "@sprincer/config": "workspace:*",
    "@types/bun": "^1.2.5",
    "typescript": "^5.8.2"
  }
}
