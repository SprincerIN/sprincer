{
  "name": "@sprincer/core-api",
  "version": "0.0.1",
  "private": true,
  "description": "Sprincer Core API - Elysia.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.0",
    "@elysiajs/swagger": "^1.3.0",
    "@sprincer/auth": "workspace:*",
    "@sprincer/db": "workspace:*",
    "@sprincer/email": "workspace:*",
    "@sprincer/types": "workspace:*",
    "@sprincer/vcs": "workspace:*",
    "elysia": "^1.3.0"
  },
  "devDependencies": {
    "@sprincer/config": "workspace:*",
    "@types/bun": "^1.2.5",
    "typescript": "^5.8.2"
  }
}
