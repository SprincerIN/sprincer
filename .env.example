# =============================================================================
# Sprincer — Environment Variables
# Copy to .env and fill in the values before running `docker compose up`.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=sprincer
POSTGRES_PASSWORD=sprincer
POSTGRES_DB=sprincer
POSTGRES_PORT=5432

# Full connection string used by Drizzle ORM (packages/db) and BetterAuth
DATABASE_URL=postgresql://sprincer:sprincer@localhost:5432/sprincer

# -----------------------------------------------------------------------------
# Redis (BullMQ queues + cache)
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Meilisearch (full-text search)
# -----------------------------------------------------------------------------
MEILISEARCH_PORT=7700
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=sprincer-meili-key

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=sprincer
MINIO_ROOT_PASSWORD=sprincer123
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=sprincer
MINIO_ACCESS_KEY=sprincer
MINIO_SECRET_KEY=sprincer123
# Set to true if using a real S3 or Cloudflare R2 endpoint
MINIO_FORCE_PATH_STYLE=true

# -----------------------------------------------------------------------------
# BetterAuth
# Generate BETTER_AUTH_SECRET with: openssl rand -base64 32
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
# Base URL of apps/core-api (internal, not internet-facing)
BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Social OAuth — Auth scopes only (NOT VCS scopes — those are separate apps)
# Google: https://console.cloud.google.com
# GitHub: https://github.com/settings/developers
# GitLab: https://gitlab.com/-/user_settings/applications
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email (Resend — https://resend.com)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_
EMAIL_FROM=Sprincer <noreply@yourdomain.com>

# -----------------------------------------------------------------------------
# Internal service communication
# Shared secret between apps/web-bff and apps/core-api.
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
INTERNAL_SERVICE_TOKEN=change-me-generate-with-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# CORS
# Allowed origin(s) for apps/web-bff. In production set to your domain.
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3200

# -----------------------------------------------------------------------------
# App ports (optional overrides — defaults match docker-compose.yml)
# -----------------------------------------------------------------------------
CORE_API_PORT=3000
WEB_BFF_PORT=3001
WEB_PORT=3200
